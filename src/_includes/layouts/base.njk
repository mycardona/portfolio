<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% if title %}{{ title }} | {% endif %}Portfolio</title>
    <meta name="description" content="A portfolio powered by Eleventy and Decap CMS.">
    <link rel="stylesheet" href="{{ '/assets/site.css' | url }}">
  </head>
  <body>
    <header class="site-header">
      <div class="container header-row">
        <a class="brand" href="{{ '/' | url }}">Mylo Portfolio</a>
        <nav class="site-nav" aria-label="Primary">
          <a href="{{ '/' | url }}">Portfolio</a>
          <a href="{{ '/projects/' | url }}">All Projects</a>
          <a href="{{ '/admin/' | url }}">Admin</a>
        </nav>
      </div>
    </header>

    <main class="container">
      {{ content | safe }}
    </main>

    <footer class="site-footer">
      <div class="container">Built with Eleventy + Decap CMS</div>
    </footer>
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  </body>
</html>
