---
layout: layouts/base.njk
---
<article class="project-detail">
  <p class="back-link"><a href="{{ '/' | url }}">← Back to portfolio</a></p>
  <header class="project-detail-header">
    <p class="eyebrow">Project</p>
    <h1>{{ title }}</h1>
    {% if summary %}
      <p class="lead">{{ summary }}</p>
    {% endif %}
    <p class="meta">{{ page.date | readableDate }}</p>
  </header>

  {% set pageCategories = categories | asArray %}
  {% if pageCategories.length %}
    <ul class="category-list category-list-inline">
      {% for category in pageCategories %}
        <li><a class="category-pill" href="{{ category | categoryUrl }}">{{ category | categoryLabel }}</a></li>
      {% endfor %}
    </ul>
  {% endif %}

  {% if coverImage %}
    <figure class="project-lead-image">
      {% optimizedImage coverImage, title %}
    </figure>
  {% endif %}

  {% if mediaUrl %}
    <section class="detail-section">
      <h2>Video / Audio</h2>
      {{ mediaUrl | mediaEmbed(title) | safe }}
    </section>
  {% endif %}

  {% if gallery and gallery.length %}
    <section class="detail-section">
      <h2>Gallery</h2>
      <div class="gallery-grid">
        {% for item in gallery %}
          {% set imageSrc = item | galleryItemSrc %}
          {% if imageSrc %}
            <figure>
              {% optimizedImage imageSrc, title %}
            </figure>
          {% endif %}
        {% endfor %}
      </div>
    </section>
  {% endif %}

  <section class="prose detail-section">
    {{ content | safe }}
  </section>
</article>
