<article class="card project-card">
  {% if project.data.coverImage %}
    <a href="{{ project.url }}" class="card-image">
      {% optimizedImage project.data.coverImage, project.data.title %}
    </a>
  {% endif %}
  <div class="card-body">
    <p class="meta card-date">{{ project.date | readableDate }}</p>

    {% if headingLevel == "h3" %}
      <h3 class="card-title"><a href="{{ project.url }}">{{ project.data.title }}</a></h3>
    {% else %}
      <h2 class="card-title"><a href="{{ project.url }}">{{ project.data.title }}</a></h2>
    {% endif %}

    {% set projectCategories = project.data.categories | asArray %}
    {% if projectCategories.length %}
      <ul class="category-list category-list-inline">
        {% for category in projectCategories %}
          <li><a class="category-pill" href="{{ category | categoryUrl }}">{{ category | categoryLabel }}</a></li>
        {% endfor %}
      </ul>
    {% endif %}

    {% if project.data.summary %}
      <p class="card-summary">{{ project.data.summary }}</p>
    {% endif %}

    <p class="card-footer"><a class="card-link" href="{{ project.url }}">Read project</a></p>
  </div>
</article>
