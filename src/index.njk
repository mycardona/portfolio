---
layout: layouts/base.njk
title: Portfolio
showQuickNav: false
---
{% set heroImage = "/uploads/hero_image.jpg" %}
{% set heroImagePosition = "28% 16%" %}
{% set bookNowUrl = '/book/' | url %}
{% set homepageCategories = collections.categories %}
{% set reelGroups = collections.reelGroups or [] %}
{% set pressQuotes = collections.pressQuotes or [] %}
{% set homepageContent = homepage or {} %}
{% set homepageHero = homepageContent.hero or {} %}
{% set homepageSelectedWork = homepageContent.selectedWork or {} %}
{% set homepageReel = homepageContent.reel or {} %}
{% set homepagePress = homepageContent.press or {} %}
{% set homepageUpcoming = homepageContent.upcoming or {} %}

<section class="landing-hero"{% if heroImage %} style="--landing-hero-image: url('{{ heroImage | assetUrl }}'); --landing-hero-position: {{ heroImagePosition }};"{% endif %}>
  <div class="landing-hero-inner">
    <div class="landing-hero-content">
      <p class="hero-kicker">{{ homepageHero.kicker or "Cool Guy" }}</p>
      <h1><span>{{ homepageHero.firstName or "MYLO" }}</span><span>{{ homepageHero.lastName or "CARDONA" }}</span></h1>
      <p class="landing-hero-role">{{ homepageHero.role or "Watermelons. Drag. Theater." }}</p>
      <p class="hero-positioning">{{ homepageHero.positioning or "A multi-disciplinary artist with cinematic magnetism. Magnetic movies. You heard it here first." }}</p>
      <div class="hero-actions">
        <a class="button hero-button" href="#reel">{{ homepageHero.primaryCtaLabel or "WATCH" }}</a>
        <a class="button button-ghost hero-button-ghost" href="{{ bookNowUrl }}">{{ homepageHero.secondaryCtaLabel or "BOOK" }}</a>
      </div>
    </div>
  </div>
</section>

<section id="selected-work" class="content-section selected-work" aria-label="Selected work">
  <div class="selected-work-head">
    <p class="eyebrow">{{ homepageSelectedWork.eyebrow or "Selected Work" }}</p>
    <h3 style="font-family: var(--font-body); font-weight: 600;">{{ homepageSelectedWork.summary or "A curated set of real projects, definitely not test data." }}</h3>
  </div>
  <div class="selected-work-grid">
    {% for category in homepageCategories %}
      {% set categoryCount = 0 %}
      {% set categoryImage = '' %}
      {% for categoryPage in collections.projectCategoryPages %}
        {% if categoryPage.slug == category.slug %}
          {% set categoryCount = categoryPage.projects.length %}
          {% if categoryPage.projects.length %}
            {% set categoryImage = categoryPage.projects[0] | projectPreviewImage %}
          {% endif %}
        {% endif %}
      {% endfor %}
      <article class="selected-work-card"{% if categoryImage %} style="--selected-card-image: url('{{ categoryImage | assetUrl }}');"{% endif %}>
        <a href="{{ category | categoryUrl }}" class="selected-work-link">
          <p class="selected-work-label">{{ category.name | categoryLabel }}</p>
          {% if category.description %}
            <p class="selected-work-copy">{{ category.description }}</p>
          {% else %}
            <p class="selected-work-copy">{{ homepageSelectedWork.defaultCardCopy or "A focused body of work currently in development." }}</p>
          {% endif %}
          {% if categoryCount %}
            <p class="selected-work-count">{{ categoryCount }} project{% if categoryCount != 1 %}s{% endif %}</p>
          {% else %}
            <p class="selected-work-count">{{ homepageSelectedWork.emptyCardStatus or "In development" }}</p>
          {% endif %}
        </a>
      </article>
    {% endfor %}
  </div>
</section>

<section id="reel" class="content-section reel-block" aria-label="Reels">
  <div class="reel-block-head">
    <p class="eyebrow">{{ homepageReel.eyebrow or "Reel" }}</p>
    <h3 style="font-family: var(--font-body); font-weight: 600;">{{ homepageReel.summary or "Watch Mylo move -- not creepy at all." }}</h3>
  </div>
  {% if reelGroups.length %}
    <div class="reel-tabs" role="tablist" aria-label="Reel versions">
      {% for group in reelGroups %}
        {% set panelId = "reel-panel-" ~ loop.index %}
        <button class="reel-tab{% if loop.first %} is-active{% endif %}" role="tab" type="button" data-reel-target="{{ panelId }}" aria-selected="{% if loop.first %}true{% else %}false{% endif %}" aria-controls="{{ panelId }}">{{ group.label }}</button>
      {% endfor %}
    </div>
    <div class="reel-panels">
      {% for group in reelGroups %}
        {% set panelId = "reel-panel-" ~ loop.index %}
        <div class="reel-panel{% if loop.first %} is-active{% endif %}" id="{{ panelId }}" role="tabpanel"{% if not loop.first %} hidden{% endif %}>
          <div class="reel-carousel" data-reel-carousel>
            <div class="reel-carousel-stage{% if group.videos.length > 1 %} has-controls{% endif %}">
              {% if group.videos.length > 1 %}
                <button class="reel-carousel-arrow" type="button" data-reel-direction="prev" aria-label="Previous {{ group.label }} video">&lt;</button>
              {% endif %}
              <div class="reel-slides">
                {% for video in group.videos %}
                  <div class="reel-slide{% if loop.first %} is-active{% endif %}" data-reel-slide{% if not loop.first %} hidden{% endif %}>
                    {{ video.data.mediaUrl | mediaEmbed(video.data.title) | safe }}
                    {% if video.data.title %}
                      <p class="reel-slide-label">{{ video.data.title }}</p>
                    {% endif %}
                  </div>
                {% endfor %}
              </div>
              {% if group.videos.length > 1 %}
                <button class="reel-carousel-arrow" type="button" data-reel-direction="next" aria-label="Next {{ group.label }} video">&gt;</button>
              {% endif %}
            </div>
            {% if group.videos.length > 1 %}
              <p class="reel-carousel-counter" data-reel-counter>1 / {{ group.videos.length }}</p>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  {% else %}
    <p class="reel-empty">{{ homepageReel.emptyMessage or "Add a video in the CMS to activate this reel block." }}</p>
  {% endif %}
</section>

<section class="content-section press-strip" aria-label="Press and testimonials">
  <p class="eyebrow">{{ homepagePress.eyebrow or "Press + Testimonials" }}</p>
  {% if pressQuotes.length %}
    <div class="press-grid">
      {% for pressQuote in pressQuotes %}
        {% if loop.index <= 4 %}
          <blockquote class="press-quote press-quote--placard" data-press-variant="placard">
            {% if pressQuote.sourceUrl %}
              <a class="press-quote-link" href="{{ pressQuote.sourceUrl | assetUrl }}">
                <p class="press-quote-text">{{ pressQuote.quote }}</p>
                {% if pressQuote.source or pressQuote.sourceUrl %}
                  <footer class="press-quote-source">
                    <cite>{{ pressQuote.source or 'Read source' }}</cite>
                  </footer>
                {% endif %}
              </a>
            {% else %}
              <p class="press-quote-text">{{ pressQuote.quote }}</p>
              {% if pressQuote.source %}
                <footer class="press-quote-source">
                  <cite>{{ pressQuote.source }}</cite>
                </footer>
              {% endif %}
            {% endif %}
          </blockquote>
        {% endif %}
      {% endfor %}
    </div>
  {% else %}
    <p class="press-empty">{{ homepagePress.emptyMessage or "Add a press quote in the CMS to activate this section." }}</p>
  {% endif %}
</section>

<section class="content-section upcoming-block" aria-label="Current and upcoming">
  <div class="upcoming-head">
    <p class="eyebrow">{{ homepageUpcoming.eyebrow or "Current + Upcoming" }}</p>
    <a href="{{ '/book/' | url }}" class="upcoming-link">{{ homepageUpcoming.bookingLinkLabel or "Booking inquiries" }}</a>
  </div>
  <div class="upcoming-grid">
    {% for project in collections.projects %}
      {% if loop.index <= 3 %}
        {% set upcomingCardImage = project | projectPreviewImage %}
        <article class="upcoming-card"{% if upcomingCardImage %} style="--upcoming-card-image: url('{{ upcomingCardImage | assetUrl }}');"{% endif %}>
          <p class="upcoming-date">{{ project.date | readableDate }}</p>
          <h3><a href="{{ project.url | url }}">{{ project.data.title }}</a></h3>
          {% set projectSummary = project.data.summary or (project.templateContent | excerpt(120)) %}
          {% if projectSummary %}
            <p>{{ projectSummary }}</p>
          {% endif %}
        </article>
      {% endif %}
    {% endfor %}
  </div>
</section>

{% if reelGroups.length %}
  <script>
    (() => {
      const reelBlock = document.querySelector(".reel-block");
      if (!reelBlock) return;

      const tabs = Array.from(reelBlock.querySelectorAll(".reel-tab"));
      const panels = Array.from(reelBlock.querySelectorAll(".reel-panel"));

      if (tabs.length > 1 && panels.length) {
        tabs.forEach((tab) => {
          tab.addEventListener("click", () => {
            const target = tab.dataset.reelTarget;
            const nextPanel = reelBlock.querySelector(`#${target}`);
            if (!nextPanel) return;

            tabs.forEach((button) => {
              const active = button === tab;
              button.classList.toggle("is-active", active);
              button.setAttribute("aria-selected", active ? "true" : "false");
            });

            panels.forEach((panel) => {
              const active = panel === nextPanel;
              panel.classList.toggle("is-active", active);
              panel.hidden = !active;
            });
          });
        });
      }

      const carousels = Array.from(reelBlock.querySelectorAll("[data-reel-carousel]"));

      carousels.forEach((carousel) => {
        const slides = Array.from(carousel.querySelectorAll("[data-reel-slide]"));
        if (slides.length <= 1) return;

        let currentIndex = 0;
        const counter = carousel.querySelector("[data-reel-counter]");
        const controls = Array.from(carousel.querySelectorAll("[data-reel-direction]"));

        const render = () => {
          slides.forEach((slide, index) => {
            const active = index === currentIndex;
            slide.classList.toggle("is-active", active);
            slide.hidden = !active;
          });

          if (counter) {
            counter.textContent = `${currentIndex + 1} / ${slides.length}`;
          }
        };

        controls.forEach((control) => {
          control.addEventListener("click", () => {
            const direction = control.dataset.reelDirection === "prev" ? -1 : 1;
            currentIndex = (currentIndex + direction + slides.length) % slides.length;
            render();
          });
        });

        render();
      });
    })();
  </script>
{% endif %}
