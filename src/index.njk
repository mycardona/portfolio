---
layout: layouts/base.njk
title: Portfolio
---
<section class="hero">
  <p class="eyebrow">Simple, zero-dollar publishing</p>
  <h1>Portfolio</h1>
  <p>Use <code>/admin</code> to add projects with text, photos, and optional video/audio links.</p>
  <a class="button" href="{{ '/projects/' | url }}">View all projects</a>
</section>

{% if collections.projectCategories.length %}
  <section class="category-section">
    <div class="section-heading">
      <h2>Browse by Category</h2>
    </div>
    <section class="category-grid">
      {% for category in collections.projectCategories %}
        <article class="category-card">
          <h3><a href="{{ category | categoryUrl }}">{{ category.name }}</a></h3>
          <p class="meta">{{ category.count }} project{% if category.count != 1 %}s{% endif %}</p>
        </article>
      {% endfor %}
    </section>
  </section>
{% endif %}

<section>
  <div class="section-heading">
    <h2>Recent Projects</h2>
  </div>

  {% if collections.projects.length %}
    <div class="project-grid">
      {% for project in collections.projects %}
        {% if loop.index <= 6 %}
          {% set headingLevel = "h3" %}
          {% include "project-card.njk" %}
        {% endif %}
      {% endfor %}
    </div>
  {% else %}
    <p>No projects yet. Add one in <a href="{{ '/admin/' | url }}">the CMS</a>.</p>
  {% endif %}
</section>
