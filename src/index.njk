---
layout: layouts/base.njk
title: Portfolio
---
<section class="landing-hero">
  <p class="eyebrow">Portfolio directory</p>
  <h1>Browse the work by category.</h1>
  <p class="hero-copy">
    Each category has its own page, so visitors can move directly into original work, directorship work,
    performance work, and more.
  </p>
  <div class="hero-actions">
    <a class="button" href="{{ '/projects/' | url }}">View all projects</a>
    <a class="button button-secondary" href="{{ '/admin/' | url }}">Add a project</a>
  </div>
</section>

{% if collections.projectCategoryPages.length %}
  <section class="category-section">
    <div class="section-heading">
      <h2>Project Categories</h2>
      <p class="meta">Every card below links to its own category page.</p>
    </div>
    <section class="category-grid">
      {% for categoryPage in collections.projectCategoryPages %}
        {% set latestProject = categoryPage.projects[0] %}
        {% set categoryImage = latestProject | projectPreviewImage %}
        {% set latestDescription = "" %}
        {% if latestProject %}
          {% set latestDescription = latestProject.data.summary or (latestProject.templateContent | excerpt(120)) %}
        {% endif %}
        <article class="category-card">
          {% if categoryImage %}
            <a href="{{ categoryPage | categoryUrl }}" class="category-image">
              {% optimizedImage categoryImage, latestProject.data.title %}
            </a>
          {% endif %}
          <div class="category-card-body">
            <p class="category-label">Category</p>
            <h3><a href="{{ categoryPage | categoryUrl }}">{{ categoryPage.name | categoryLabel }}</a></h3>
            <p class="meta">{{ categoryPage.projects.length }} project{% if categoryPage.projects.length != 1 %}s{% endif %}</p>
            {% if latestProject %}
              <p class="category-latest">Latest: <a href="{{ latestProject.url }}">{{ latestProject.data.title }}</a></p>
              {% if latestDescription %}
                <p class="card-summary">{{ latestDescription }}</p>
              {% endif %}
            {% endif %}
            {% if categoryPage.projects.length %}
              <ul class="category-preview-list">
                {% for project in categoryPage.projects %}
                  {% if loop.index <= 3 %}
                    <li><a href="{{ project.url }}">{{ project.data.title }}</a></li>
                  {% endif %}
                {% endfor %}
              </ul>
            {% endif %}
            <p><a class="category-link" href="{{ categoryPage | categoryUrl }}">Open category page</a></p>
          </div>
        </article>
      {% endfor %}
    </section>
  </section>
{% endif %}

<section>
  <div class="section-heading">
    <h2>Recent Projects</h2>
  </div>

  {% if collections.projects.length %}
    <div class="project-grid">
      {% for project in collections.projects %}
        {% if loop.index <= 6 %}
          {% set headingLevel = "h3" %}
          {% include "project-card.njk" %}
        {% endif %}
      {% endfor %}
    </div>
  {% else %}
    <p>No projects yet. Add one in <a href="{{ '/admin/' | url }}">the CMS</a>.</p>
  {% endif %}
</section>
