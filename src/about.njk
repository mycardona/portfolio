---
layout: layouts/base.njk
title: About
permalink: /about/
---
{% set aboutHero = (about and about.hero) or {} %}
{% set aboutDetail = (about and about.detail) or {} %}
{% set aboutSections = aboutDetail.sections or [] %}
{% set aboutResume = (about and about.resume) or {} %}
{% set aboutResumeMain = aboutResume.main or {} %}
{% set aboutResumeSide = aboutResume.side or {} %}
{% set resumeContactUrl = aboutResume.contactUrl or '/book/' %}

<section class="about-hero">
  {% if aboutHero.eyebrow %}
    <p class="eyebrow">{{ aboutHero.eyebrow }}</p>
  {% endif %}
  {% if aboutHero.title %}
    <h1>{{ aboutHero.title }}</h1>
  {% endif %}
  {% if aboutHero.lead %}
    <p class="about-lead">{{ aboutHero.lead }}</p>
  {% endif %}
</section>

{% if aboutSections.length %}
  <section class="about-layout" aria-label="About details">
    {% for section in aboutSections %}
      {% set sectionParagraphs = section.paragraphs or [] %}
      <article class="about-panel">
        {% if section.title %}
          <h2>{{ section.title }}</h2>
        {% endif %}
        {% for paragraph in sectionParagraphs %}
          {% if paragraph %}
            <p>{{ paragraph }}</p>
          {% endif %}
        {% endfor %}
      </article>
    {% endfor %}
  </section>
{% endif %}

<section class="resume-inline" aria-label="Acting resume">
  <div class="resume-header">
    {% if aboutResume.eyebrow %}
      <p class="eyebrow">{{ aboutResume.eyebrow }}</p>
    {% endif %}
    {% if aboutResume.title %}
      <h2>{{ aboutResume.title }}</h2>
    {% endif %}
  </div>

  <article class="resume-paper">
    <header class="resume-paper-head">
      <div class="resume-head-main">
        {% if aboutResume.name %}
          <p class="resume-name">{{ aboutResume.name }}</p>
        {% endif %}
        {% if aboutResume.tagline %}
          <p class="resume-tagline">{{ aboutResume.tagline }}</p>
        {% endif %}
      </div>
      <div class="resume-head-contact">
        {% if aboutResume.contactTitle %}
          <a class="resume-contact-title" href="{{ resumeContactUrl | assetUrl }}">{{ aboutResume.contactTitle }}</a>
        {% endif %}
        {% if aboutResume.contactNote %}
          <p class="resume-contact-note">{{ aboutResume.contactNote }}</p>
        {% endif %}
      </div>
    </header>

    <div class="resume-paper-body">
      <div class="resume-column resume-column-main">
        <section class="resume-block">
          {% if aboutResumeMain.stageHeading %}
            <h3>{{ aboutResumeMain.stageHeading }}</h3>
          {% endif %}
          <ul class="resume-credits">
            {% for credit in aboutResumeMain.stageCredits or [] %}
              <li>
                {% if credit.role %}
                  <p class="credit-role">{{ credit.role }}</p>
                {% endif %}
                {% if credit.showTitle or credit.director or credit.details %}
                  <p class="credit-meta">
                    {% if credit.showTitle %}
                      <span class="show-title">"{{ credit.showTitle }}"</span>
                    {% endif %}
                    {% if credit.director %}
                      {% if credit.showTitle %} {% endif %}Dir: {{ credit.director }}
                    {% endif %}
                    {% if credit.details %}
                      <br>{{ credit.details }}
                    {% endif %}
                  </p>
                {% endif %}
              </li>
            {% endfor %}
          </ul>
        </section>

        <section class="resume-block">
          {% if aboutResumeMain.filmHeading %}
            <h3>{{ aboutResumeMain.filmHeading }}</h3>
          {% endif %}
          <ul class="resume-credits">
            {% for credit in aboutResumeMain.filmCredits or [] %}
              <li>
                {% if credit.role %}
                  <p class="credit-role">{{ credit.role }}</p>
                {% endif %}
                {% if credit.showTitle or credit.director or credit.details %}
                  <p class="credit-meta">
                    {% if credit.showTitle %}
                      <span class="show-title">"{{ credit.showTitle }}"</span>
                    {% endif %}
                    {% if credit.director %}
                      {% if credit.showTitle %} {% endif %}Dir: {{ credit.director }}
                    {% endif %}
                    {% if credit.details %}
                      <br>{{ credit.details }}
                    {% endif %}
                  </p>
                {% endif %}
              </li>
            {% endfor %}
          </ul>
        </section>

        <section class="resume-block">
          {% if aboutResumeMain.recognitionHeading %}
            <h3>{{ aboutResumeMain.recognitionHeading }}</h3>
          {% endif %}
          <ul class="resume-list resume-list-dated">
            {% for item in aboutResumeMain.recognitionItems or [] %}
              <li>
                {% if item.date %}
                  <span class="list-date">{{ item.date }}</span>
                {% endif %}
                {% if item.text %}
                  <span class="list-text">{{ item.text }}</span>
                {% endif %}
              </li>
            {% endfor %}
          </ul>
        </section>
      </div>

      <aside class="resume-column resume-column-side">
        <section class="resume-block">
          {% if aboutResumeSide.worksHeading %}
            <h3>{{ aboutResumeSide.worksHeading }}</h3>
          {% endif %}
          <ul class="resume-credits resume-credits-dated">
            {% for item in aboutResumeSide.worksItems or [] %}
              <li>
                {% if item.date %}
                  <p class="credit-date">{{ item.date }}</p>
                {% endif %}
                <div>
                  {% if item.role %}
                    <p class="credit-role">{{ item.role }}</p>
                  {% endif %}
                  {% if item.highlight or item.details %}
                    <p class="credit-meta">
                      {% if item.highlight %}
                        <span class="credit-highlight">{{ item.highlight }}</span>
                      {% endif %}
                      {% if item.details %}
                        {% if item.highlight %}<br>{% endif %}{{ item.details }}
                      {% endif %}
                    </p>
                  {% endif %}
                </div>
              </li>
            {% endfor %}
          </ul>
        </section>

        <section class="resume-block">
          {% if aboutResumeSide.skillsHeading %}
            <h3>{{ aboutResumeSide.skillsHeading }}</h3>
          {% endif %}
          <ul class="resume-list resume-list-skill-columns">
            {% for skill in aboutResumeSide.skills or [] %}
              {% if skill %}
                <li>{{ skill }}</li>
              {% endif %}
            {% endfor %}
          </ul>
        </section>

        <section class="resume-block">
          {% if aboutResumeSide.trainingHeading %}
            <h3>{{ aboutResumeSide.trainingHeading }}</h3>
          {% endif %}
          <ul class="resume-list resume-list-dated">
            {% for item in aboutResumeSide.trainingItems or [] %}
              <li>
                {% if item.date %}
                  <span class="list-date">{{ item.date }}</span>
                {% endif %}
                {% if item.text %}
                  <span class="list-text">{{ item.text }}</span>
                {% endif %}
              </li>
            {% endfor %}
          </ul>
        </section>
      </aside>
    </div>
  </article>
</section>
