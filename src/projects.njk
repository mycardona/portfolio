---
layout: layouts/base.njk
title: Projects
permalink: /projects/
---
<section class="page-intro archive-intro">
  <p class="eyebrow">Selected projects by Mylo Cardona</p>
  <p>A curated view of performance, original, and collaborative projects.</p>
  {% if collections.projectCategories.length %}
    <div class="category-intro-nav">
      <p class="meta">Explore by discipline:</p>
      <ul class="category-list">
        {% for category in collections.projectCategories %}
          <li><a class="category-pill" href="{{ category | categoryUrl }}">{{ category.name | categoryLabel }}</a></li>
        {% endfor %}
      </ul>
    </div>
  {% endif %}
</section>

{% if collections.projects.length %}
  <div class="project-grid">
    {% for project in collections.projects %}
      {% set projectHref = project.url | url %}
      <article class="card project-card">
        {% set previewImage = project | projectPreviewImage %}
        {% if previewImage %}
          <a href="{{ projectHref }}" class="card-image">
            {% optimizedImage previewImage, project.data.title %}
          </a>
        {% endif %}
        <div class="card-body">
          <p class="meta card-date">{{ project.date | readableDate }}</p>
          {% if project.data.venueName %}
            <p class="meta card-venue">
              {% if project.data.venueUrl %}
                <a href="{{ project.data.venueUrl }}" target="_blank" rel="noopener noreferrer">{{ project.data.venueName }}</a>
              {% else %}
                {{ project.data.venueName }}
              {% endif %}
            </p>
          {% endif %}
          <h2 class="card-title"><a href="{{ projectHref }}">{{ project.data.title }}</a></h2>
          {% set projectCategories = project.data.categories | asArray %}
          {% if projectCategories.length %}
            <ul class="category-list category-list-inline">
              {% for category in projectCategories %}
                <li><a class="category-pill" href="{{ category | categoryUrl }}">{{ category | categoryLabel }}</a></li>
              {% endfor %}
            </ul>
          {% endif %}
          {% set cardSummary = project.data.summary or (project.templateContent | excerpt(170)) %}
          {% if cardSummary %}
            <p class="card-summary">{{ cardSummary }}</p>
          {% endif %}
        </div>
      </article>
    {% endfor %}
  </div>
{% else %}
  <p>No public projects available yet.</p>
{% endif %}
