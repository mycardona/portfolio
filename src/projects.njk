---
layout: layouts/base.njk
title: Projects
permalink: /projects/
---
<section class="page-intro">
  <p class="eyebrow">Portfolio index</p>
  <h1>All Projects</h1>
  <p>Prefer browsing by category? Visit the <a href="{{ '/' | url }}">portfolio landing page</a>.</p>
</section>

{% if collections.projectCategories.length %}
  <section class="category-nav">
    <p class="meta">Jump to a category page:</p>
    <ul class="category-list">
      {% for category in collections.projectCategories %}
        <li><a class="category-pill" href="{{ category | categoryUrl }}">{{ category.name | categoryLabel }}</a></li>
      {% endfor %}
    </ul>
  </section>
{% endif %}

{% if collections.projects.length %}
  <div class="project-grid">
    {% for project in collections.projects %}
      {% set headingLevel = "h2" %}
      {% include "project-card.njk" %}
    {% endfor %}
  </div>
{% else %}
  <p>No projects yet. Add the first one in <a href="{{ '/admin/' | url }}">the CMS</a>.</p>
{% endif %}
