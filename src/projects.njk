---
layout: layouts/base.njk
title: Projects
permalink: /projects/
---
<section class="section-heading">
  <h1>All Projects</h1>
  <p>Prefer browsing by category? Visit the <a href="/portfolio/">portfolio landing page</a>.</p>
</section>

{% if collections.projects.length %}
  <div class="project-grid">
    {% for project in collections.projects %}
      {% set headingLevel = "h2" %}
      {% include "project-card.njk" %}
    {% endfor %}
  </div>
{% else %}
  <p>No projects yet. Add the first one in <a href="/admin/">the CMS</a>.</p>
{% endif %}
