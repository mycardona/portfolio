---
layout: layouts/base.njk
pagination:
  data: collections.projectCategoryPages
  size: 1
  alias: categoryPage
permalink: "/category/{{ categoryPage.slug }}/"
eleventyComputed:
  title: "{{ categoryPage.name | categoryLabel }}"
---
<section class="page-intro category-intro">
  <p class="back-link"><a href="{{ '/' | url }}">Back to home</a></p>
  <p class="eyebrow">Discipline</p>
  <h1>{{ categoryPage.name | categoryLabel }}</h1>
  <p class="meta">{{ categoryPage.projects.length }} work{% if categoryPage.projects.length != 1 %}s{% endif %}</p>
</section>

{% if collections.projectCategoryPages.length > 1 %}
  <section class="category-nav">
    <p class="meta">Explore other sections:</p>
    <ul class="category-list">
      {% for category in collections.projectCategoryPages %}
        {% if category.slug != categoryPage.slug %}
          <li><a class="category-pill" href="{{ category | categoryUrl }}">{{ category.name | categoryLabel }}</a></li>
        {% endif %}
      {% endfor %}
    </ul>
  </section>
{% endif %}

{% if categoryPage.projects.length %}
  <div class="project-grid project-grid-showcase">
    {% for project in categoryPage.projects %}
      {% set projectHref = project.url | url %}
      <article class="card project-card">
        {% set previewImage = project | projectPreviewImage %}
        {% if previewImage %}
          <a href="{{ projectHref }}" class="card-image">
            {% optimizedImage previewImage, project.data.title %}
          </a>
        {% endif %}
        <div class="card-body">
          <p class="meta card-date">{{ project.date | readableDate }}</p>
          <h2 class="card-title"><a href="{{ projectHref }}">{{ project.data.title }}</a></h2>
          {% set projectCategories = project.data.categories | asArray %}
          {% if projectCategories.length %}
            <ul class="category-list category-list-inline">
              {% for category in projectCategories %}
                <li><a class="category-pill" href="{{ category | categoryUrl }}">{{ category | categoryLabel }}</a></li>
              {% endfor %}
            </ul>
          {% endif %}
          {% set cardSummary = project.data.summary or (project.templateContent | excerpt(170)) %}
          {% if cardSummary %}
            <p class="card-summary">{{ cardSummary }}</p>
          {% endif %}
          <p class="card-footer"><a class="card-link" href="{{ projectHref }}">View project</a></p>
        </div>
      </article>
    {% endfor %}
  </div>
{% else %}
  <p>No works in this section yet.</p>
{% endif %}
