---
layout: layouts/base.njk
title: Portfolio
permalink: /portfolio/
---
<section class="section-heading">
  <h1>Portfolio</h1>
  <p>Browse projects by category.</p>
</section>

{% if collections.projectCategories.length %}
  <section class="category-grid">
    {% for category in collections.projectCategories %}
      <article class="category-card">
        <h2><a href="{{ category | categoryUrl }}">{{ category.name }}</a></h2>
        <p class="meta">{{ category.count }} project{% if category.count != 1 %}s{% endif %}</p>
      </article>
    {% endfor %}
  </section>
{% else %}
  <p>No categories yet. Add a category to a project in <a href="/admin/">the CMS</a>.</p>
{% endif %}

{% if collections.projects.length %}
  <section class="category-section">
    <h2>Recent Projects</h2>
    <div class="project-grid">
      {% for project in collections.projects %}
        {% if loop.index <= 6 %}
          {% set headingLevel = "h3" %}
          {% include "project-card.njk" %}
        {% endif %}
      {% endfor %}
    </div>
  </section>
{% endif %}
